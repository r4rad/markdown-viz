{
  "name": "markdown-viz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Lightweight, performance-oriented Markdown editor, viewer & beautifier with multi-tab sessions, VS Code-like themes, and diagram support",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "lodash-es": ">=4.17.24"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@emailjs/browser": "^4.4.1",
    "@types/dompurify": "^3.0.5",
    "@viz-js/viz": "^3.25.0",
    "codemirror": "^6.0.2",
    "dompurify": "^3.3.3",
    "firebase": "^12.11.0",
    "highlight.js": "^11.11.1",
    "html-docx-js-typescript": "^0.1.5",
    "html2canvas": "^1.4.1",
    "idb-keyval": "^6.2.2",
    "jspdf": "^4.2.1",
    "katex": "^0.16.44",
    "mammoth": "^1.12.0",
    "marked": "^17.0.5",
    "mermaid": "^11.13.0",
    "nomnoml": "^1.7.0",
    "pdfjs-dist": "^5.6.205",
    "prettier": "^3.8.1",
    "yjs": "^13.6.30"
  }
}
