# Firebase Configuration
# Get these from: Firebase Console > Project Settings > Your apps > Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloud sync settings
# Maximum number of tabs synced to cloud per user (default: 10)
VITE_MAX_SYNC_TABS=10
# Auto-sync interval in seconds for logged-in users (default: 60)
VITE_AUTO_SYNC_INTERVAL_SECONDS=60

# EmailJS integration for feedback emails (optional)
# Sign up at https://www.emailjs.com — all three vars required to enable email delivery
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
# Recipient email address for feedback (default: rad.rafatahmad@gmail.com)
VITE_FEEDBACK_EMAIL=rad.rafatahmad@gmail.com

# Sharing feature (default: true)
# Set to "false" to disable document sharing via URL
VITE_ENABLE_SHARING=true

# Groq API key for AI audio summaries (optional but recommended)
# Free tier: 30 req/min, 14,400 req/day — sign up at https://console.groq.com/keys
# When set, the app uses llama-3.1-8b-instant to generate human-quality spoken summaries.
# Without this key, the app falls back to an extractive text algorithm.
# Can also be entered at runtime via Settings → AI Audio (stored in localStorage).
VITE_GROQ_API_KEY=

